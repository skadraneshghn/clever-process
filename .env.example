# ---- Server ----
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true
LOG_LEVEL=info

# ---- Camoufox / stealth browser ----
# For local testing keep this false so you can watch the browser.
# In production set to "virtual" (Linux Xvfb) or true.
BROWSER_HEADLESS=false

# Humanize cursor movement: true, or a max duration in seconds (e.g. 1.5)
BROWSER_HUMANIZE=true

# Auto-detect geolocation/timezone/locale from the outbound IP (defeats proxy
# leaks). Set to true, or to a specific IP address.
BROWSER_GEOIP=true

# Operating-system fingerprint(s) to rotate through.
# Comma separated subset of: windows,macos,linux
BROWSER_OS=windows,macos,linux

# Default locale used for the Intl API & Accept-Language.
BROWSER_LOCALE=en-US

# Privacy toggles
BROWSER_BLOCK_WEBRTC=true
BROWSER_BLOCK_IMAGES=false

# Optional upstream proxy, e.g. http://user:pass@host:port
BROWSER_PROXY=

# Max concurrent pages handled by the single shared browser instance
BROWSER_MAX_CONCURRENCY=4

# Default per-request navigation timeout (milliseconds)
BROWSER_NAV_TIMEOUT_MS=45000
